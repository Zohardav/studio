
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Stores user-specific settings and progress.",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "dailyGoalGlasses": { "type": "number" },
        "totalStars": { "type": "number" },
        "bonusEarnedDates": { "type": "array", "items": { "type": "string" }, "description": "Dates (YYYY-MM-DD) when the daily goal bonus was earned." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "displayName", "dailyGoalGlasses", "totalStars", "createdAt", "updatedAt"]
    },
    "WorldStage": {
      "title": "WorldStage",
      "type": "object",
      "description": "A specific visual stage in the world's evolution.",
      "properties": {
        "id": { "type": "string" },
        "stageNumber": { "type": "number" },
        "imageUrl": { "type": "string" },
        "requiredStars": { "type": "number", "description": "Total stars needed to unlock this stage." },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "stageNumber", "requiredStars", "updatedAt"]
    },
    "HydrationLog": {
      "title": "HydrationLog",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "glassesCount": { "type": "number", "default": 1 },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "glassesCount", "timestamp"]
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profile data."
    },
    "/users/{userId}/logs/{logId}": {
      "schema": { "$ref": "#/backend/entities/HydrationLog" },
      "description": "Individual water logs."
    },
    "/worldStages/{stageId}": {
      "schema": { "$ref": "#/backend/entities/WorldStage" },
      "description": "Global collection of visual world stages."
    }
  }
}
