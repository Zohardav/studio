
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Stores user-specific settings and progress.",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "dailyGoalMl": { "type": "number" },
        "preferredGlassSizeMl": { "type": "number" },
        "totalLifetimeMl": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "displayName", "dailyGoalMl", "preferredGlassSizeMl", "totalLifetimeMl", "createdAt", "updatedAt"]
    },
    "WorldStage": {
      "title": "WorldStage",
      "type": "object",
      "description": "A specific visual stage in the world's evolution.",
      "properties": {
        "id": { "type": "string" },
        "stageNumber": { "type": "number" },
        "imageUrl": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "stageNumber", "imageUrl", "updatedAt"]
    },
    "HydrationLog": {
      "title": "HydrationLog",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amountMl": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "amountMl", "timestamp"]
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profile data."
    },
    "/users/{userId}/logs/{logId}": {
      "schema": { "$ref": "#/backend/entities/HydrationLog" },
      "description": "Individual water logs."
    },
    "/worldStages/{stageId}": {
      "schema": { "$ref": "#/backend/entities/WorldStage" },
      "description": "Global collection of visual world stages, managed by developers."
    }
  }
}
