
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic sanctuary security rules for production deployment
    function isSignedIn() {
      return request.auth != null;
    }
    
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
      match /logs/{logId} {
        allow read, write: if request.auth.uid == userId;
      }
    }
    
    match /worldStages/{stageId} {
      // Allow public read access so any user (guest or authenticated) can see the world progress
      allow read: if true;
      // Allow write access for authenticated users (which includes anonymous sign-ins in this prototype)
      allow write: if isSignedIn();
    }
  }
}
