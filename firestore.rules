
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
      match /logs/{logId} {
        allow read, write: if request.auth.uid == userId;
      }
    }
    
    match /worldStages/{stageId} {
      // Allow public read access to visual progression stages
      // Only authenticated users can write (managed by developer Rituals)
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
